{
  "info": {
    "name": "AuthCore API",
    "description": "Postman collection for AuthCore backend endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "login"
              ]
            }
          }
        },
        {
          "name": "Refresh Access Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "refresh"
              ]
            }
          }
        },
        {
          "name": "Revoke Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{accessToken}}\",\n  \"type\": \"access\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/revoke",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "revoke"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Authenticated",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{accessToken}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "me"
              ]
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Password123!\",\n  \"newPassword\": \"NewPassword123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/change-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "users",
                "change-password"
              ]
            }
          }
        },
        {
          "name": "Logout Current Session",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "logout"
              ]
            }
          }
        },
        {
          "name": "Logout All Sessions",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout-all",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "logout-all"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Protected",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{accessToken}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "Protected Me",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/protected/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "protected",
                "me"
              ]
            }
          }
        },
        {
          "name": "Protected Admin Area",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/protected/admin",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "protected",
                "admin"
              ]
            }
          }
        },
        {
          "name": "Protected Manager Area",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/protected/manager",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "protected",
                "manager"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{accessToken}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/admin/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "users"
              ]
            }
          }
        },
        {
          "name": "Update User Role",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/:id/role?role=MANAGER",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "users",
                ":id",
                "role"
              ],
              "query": [
                {
                  "key": "role",
                  "value": "MANAGER"
                }
              ]
            }
          }
        },
        {
          "name": "Update User Status",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/admin/users/:id/status?enabled=false",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "admin",
                "users",
                ":id",
                "status"
              ],
              "query": [
                {
                  "key": "enabled",
                  "value": "false"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
